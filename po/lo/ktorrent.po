#, kde-format
msgid "Filter"
msgstr "ກັ່ນຕອງ"

#: ktorrent/dialogs/fileselectdlg.cpp:107
#, kde-format
msgid "Opening %1"
msgstr "ກຳລັງເປີດ %1"

#: ktorrent/dialogs/fileselectdlg.cpp:206
#, kde-format
msgid ""
"Some files of this torrent have been found in the completed downloads "
"directory. Do you want to import these files and use the completed downloads "
"directory as the location?"
msgstr ""
"ພົບບາງໄຟລ໌ຂອງທໍເຣັ້ນນີ້ໃນໂຟນເດີດາວໂຫລດທີ່ສຳເລັດແລ້ວ. ເຈົ້າຕ້ອງການນຳເຂົ້າໄຟລ໌ເຫຼົ່ານີ້ ແລະ "
"ໃຊ້ໂຟນເດີດາວໂຫລດທີ່ສຳເລັດແລ້ວເປັນບ່ອນເກັບໄຟລ໌ບໍ່?"

#: ktorrent/dialogs/fileselectdlg.cpp:210
#, kde-format
msgid ""
"All files of this torrent have been found in the completed downloads "
"directory. Do you want to import these files and use the completed downloads "
"directory as the location?"
msgstr ""
"ພົບໄຟລ໌ທັງໝົດຂອງທໍເຣັ້ນນີ້ໃນໂຟນເດີດາວໂຫລດທີ່ສຳເລັດແລ້ວ. ເຈົ້າຕ້ອງການນຳເຂົ້າໄຟລ໌ເຫຼົ່ານີ້ ແລະ "
"ໃຊ້ໂຟນເດີດາວໂຫລດທີ່ສຳເລັດແລ້ວເປັນບ່ອນເກັບໄຟລ໌ບໍ່?"

#: ktorrent/dialogs/fileselectdlg.cpp:214
#, kde-format
msgid ""
"The file <b>%1</b> was found in the completed downloads directory. Do you "
"want to import this file?"
msgstr "ພົບໄຟລ໌ <b>%1</b> ໃນໂຟນເດີດາວໂຫລດທີ່ສຳເລັດແລ້ວ. ເຈົ້າຕ້ອງການນຳເຂົ້າໄຟລ໌ນີ້ບໍ່?"

#: ktorrent/dialogs/fileselectdlg.cpp:222
#, kde-format
msgctxt "@action:button"
msgid "Import"
msgstr "ນຳເຂົ້າ"

#: ktorrent/dialogs/fileselectdlg.cpp:233
#: ktorrent/dialogs/fileselectdlg.cpp:252
#, kde-format
