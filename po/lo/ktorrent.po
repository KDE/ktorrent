#: ktorrent/pref/networkpref.ui:265 ktupnptest/upnptestwidget.ui:102
#, kde-format
msgid "TCP"
msgstr "TCP"

#. i18n: ectx: property (text), item, widget (QComboBox, kcfg_primaryTransportProtocol)
#: ktorrent/pref/networkpref.ui:270
#, kde-format
msgid "µTP"
msgstr "µTP"

