#: ktorrent/core.cpp:149
#, kde-format
msgid ""
"KTorrent is unable to accept connections because the TCP port %1 is already "
"in use by another program."
msgstr "KTorrent ບໍ່ສາມາດຮັບການເຊື່ອມຕໍ່ໄດ້ ເນື່ອງຈາກພອດ TCP %1 ກຳລັງຖືກນຳໃຊ້ໂດຍໂປຣແກຣມອື່ນ."

#: ktorrent/core.cpp:159
#, kde-format
msgid ""
"KTorrent is unable to accept connections because the UDP port %1 is already "
"in use by another program."
msgstr "KTorrent ບໍ່ສາມາດຮັບການເຊື່ອມຕໍ່ໄດ້ ເນື່ອງຈາກພອດ UDP %1 ກຳລັງຖືກນຳໃຊ້ໂດຍໂປຣແກຣມອື່ນ."

#: ktorrent/core.cpp:267
#, kde-format
msgid ""
"Opening the torrent <b>%1</b>, would share one or more files with the "
"following torrents. Torrents are not allowed to write to the same files. "
msgstr ""
"ການເປີດທໍເຣັ້ນ <b>%1</b>, ຈະເປັນການແບ່ງປັນໜຶ່ງ ຫຼື ຫຼາຍໄຟລ໌ກັບທໍເຣັ້ນຕໍ່ໄປນີ້. "
"ທໍເຣັ້ນບໍ່ໄດ້ຮັບອະນຸຍາດໃຫ້ຂຽນທັບໄຟລ໌ດຽວກັນ. "

#: ktorrent/core.cpp:873
#, kde-format
msgid "KTorrent is running one or more torrents"
msgstr "KTorrent ກຳລັງທຳງານໜຶ່ງ ຫຼື ຫຼາຍທໍເຣັ້ນ"

#: ktorrent/core.cpp:965
#, kde-format
msgid "Cannot create torrent: %1"
msgstr "ບໍ່ສາມາດສ້າງທໍເຣັ້ນໄດ້: %1"

#: ktorrent/core.cpp:1064
#, kde-format
msgid ""
"One or more storage volumes are not mounted. In order to start this torrent, "
"they need to be mounted."
msgstr ""
"ໜຶ່ງ ຫຼື ຫຼາຍພື້ນທີ່ຈັດເກັບຂໍ້ມູນ (storage volumes) ບໍ່ໄດ້ຖືກຕິດຕັ້ງ (mount). ເພື່ອເລີ່ມຕົ້ນທໍເຣັ້ນນີ້, "
"ພວກມັນຈຳເປັນຕ້ອງຖືກຕິດຕັ້ງກ່ອນ."

#: ktorrent/core.cpp:1065
#, kde-format
msgid "Retry"
msgstr "ລອງໃໝ່"

#: ktorrent/core.cpp:1071
#, kde-format
msgid "Storage volume %1 is not mounted"
msgstr "ພື້ນທີ່ຈັດເກັບຂໍ້ມູນ %1 ບໍ່ໄດ້ຖືກຕິດຕັ້ງ"

#: ktorrent/core.cpp:1073
#, kde-format
msgid "Storage volumes %1 are not mounted"
msgstr "ພື້ນທີ່ຈັດເກັບຂໍ້ມູນ %1 ບໍ່ໄດ້ຖືກຕິດຕັ້ງ"

#: ktorrent/core.cpp:1086
#, kde-format
msgid ""
"Several data files of the torrent \"%1\" are missing. \n"
"Do you want to recreate them, or do you want to not download them?"
msgstr ""
"ໄຟລ໌ຂໍ້ມູນຫຼາຍອັນຂອງທໍເຣັ້ນ \"%1\" ຫາຍໄປ. \n"
"ເຈົ້າຕ້ອງການສ້າງພວກມັນໃໝ່, ຫຼື ຕ້ອງການທີ່ຈະບໍ່ດາວໂຫລດພວກມັນ?"

#: ktorrent/core.cpp:1094 ktorrent/core.cpp:1102 ktorrent/core.cpp:1112
#, kde-format
msgid "Data files are missing"
msgstr "ໄຟລ໌ຂໍ້ມູນຫາຍໄປ"

#: ktorrent/core.cpp:1101
#, kde-format
msgid "Cannot deselect missing files: %1"
msgstr "ບໍ່ສາມາດຍົກເລີກການເລືອກໄຟລ໌ທີ່ຫາຍໄປໄດ້: %1"

#: ktorrent/core.cpp:1111
#, kde-format
msgid "Cannot recreate missing files: %1"
msgstr "ບໍ່ສາມາດສ້າງໄຟລ໌ທີ່ຫາຍໄປຄືນໃໝ່ໄດ້: %1"

#: ktorrent/core.cpp:1121
#, kde-format
msgid ""
"The file where the data is saved of the torrent \"%1\" is missing.\n"
"Do you want to recreate it?"
msgstr ""
"ໄຟລ໌ທີ່ໃຊ້ບັນທຶກຂໍ້ມູນຂອງທໍເຣັ້ນ \"%1\" ຫາຍໄປ.\n"
"ເຈົ້າຕ້ອງການສ້າງມັນຄືນໃໝ່ບໍ່?"

#: ktorrent/core.cpp:1128 ktorrent/core.cpp:1135
#, kde-format
msgid "Data file is missing"
msgstr "ໄຟລ໌ຂໍ້ມູນຫາຍໄປ"

#: ktorrent/core.cpp:1134
#, kde-format
msgid "Cannot recreate data file: %1"
msgstr "ບໍ່ສາມາດສ້າງໄຟລ໌ຂໍ້ມູນຄືນໃໝ່ໄດ້: %1"

#: ktorrent/core.cpp:1236
#, kde-format
msgid "Invalid magnet bittorrent link: %1"
msgstr "ລິງກ໌ magnet bittorrent ບໍ່ຖືກຕ້ອງ: %1"

#: ktorrent/core.cpp:1239
#, kde-format
msgid ""
"You are attempting to download a magnet link, and DHT is not enabled. For "
"optimum results enable DHT."
msgstr ""
"ເຈົ້າກຳລັງພະຍາຍາມດາວໂຫລດລິງກ໌ magnet, ແຕ່ DHT ບໍ່ໄດ້ເປີດໃຊ້ງານ. ເພື່ອຜົນລັັບທີ່ດີທີ່ສຸດ "
"ກະລຸນາເປີດໃຊ້ງານ DHT."

